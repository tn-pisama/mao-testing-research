{
  "name": "n8n-nodes-claude-thinking",
  "version": "1.0.0",
  "description": "n8n community node for Claude API with extended thinking capture",
  "keywords": [
    "n8n-community-node-package",
    "claude",
    "anthropic",
    "extended-thinking",
    "reasoning",
    "pisama"
  ],
  "license": "MIT",
  "homepage": "https://pisama.ai",
  "author": {
    "name": "PISAMA",
    "email": "support@pisama.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pisama/n8n-nodes-claude-thinking.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ClaudeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ClaudeThinking/ClaudeThinking.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.60.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.60.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0"
  }
}
