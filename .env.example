# PISAMA Platform - Environment Variables
# Copy to .env and fill in real values before running docker-compose up
#
# Generate a secure JWT secret: openssl rand -base64 32

# =============================================================================
# REQUIRED - docker-compose will fail without these
# =============================================================================

# JWT signing secret (min 32 chars, no weak patterns like "secret", "dev", etc.)
JWT_SECRET=

# PostgreSQL password (used by both postgres and backend services)
POSTGRES_PASSWORD=

# =============================================================================
# OPTIONAL - have sensible defaults in docker-compose.yml or backend config
# =============================================================================

# Backend
DATABASE_URL=postgresql+asyncpg://mao:${POSTGRES_PASSWORD}@postgres:5432/mao
REDIS_URL=redis://redis:6379
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Google OAuth (required for production auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=

# Stripe billing (required for paid plans)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTUP=
STRIPE_PRICE_ID_GROWTH=

# n8n integration (optional)
N8N_HOST=
N8N_API_KEY=
N8N_SYNC_INTERVAL_MINUTES=5

# Detection settings
EMBEDDING_MODEL=BAAI/bge-m3
LOOP_DETECTION_WINDOW=7
STRUCTURAL_THRESHOLD=0.95
SEMANTIC_THRESHOLD=0.85

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Observability
OTEL_SERVICE_NAME=mao-platform

# AWS Marketplace (optional)
AWS_MARKETPLACE_ENABLED=false
AWS_MARKETPLACE_PRODUCT_CODE=
AWS_MARKETPLACE_REGION=us-east-1

# Feature flags (all default to false)
FEATURE_ENTERPRISE_ENABLED=false
FEATURE_ML_DETECTION=false
FEATURE_ADVANCED_EVALS=false
FEATURE_CHAOS_ENGINEERING=false
FEATURE_TRACE_REPLAY=false
FEATURE_REGRESSION_TESTING=false
FEATURE_QUALITY_ASSESSMENT=false
FEATURE_COGNITIVE_MEMORY=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
