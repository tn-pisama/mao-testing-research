{
  "description": "Adversarial test cases for F8 (Infinite Loop) detector",
  "purpose": "Test edge cases where legitimate patterns may look like loops",
  "source": "Based on Anthropic 'Demystifying evals' article - need harder cases for saturated detectors",
  "cases": [
    {
      "case_id": "F8_ADV_001",
      "description": "Legitimate retry with exponential backoff",
      "expected_detection": false,
      "difficulty": "hard",
      "reason": "Pattern shows repeated calls but with increasing delays (200ms, 400ms, 800ms, 1600ms)",
      "trace": {
        "execution_id": "adv-f8-001",
        "workflow_name": "api-retry-workflow",
        "events": [
          {"timestamp": "2024-01-01T10:00:00.000Z", "node": "HTTP Request", "action": "call_api", "result": "error_503"},
          {"timestamp": "2024-01-01T10:00:00.200Z", "node": "HTTP Request", "action": "retry_1", "delay_ms": 200, "result": "error_503"},
          {"timestamp": "2024-01-01T10:00:00.600Z", "node": "HTTP Request", "action": "retry_2", "delay_ms": 400, "result": "error_503"},
          {"timestamp": "2024-01-01T10:00:01.400Z", "node": "HTTP Request", "action": "retry_3", "delay_ms": 800, "result": "error_503"},
          {"timestamp": "2024-01-01T10:00:03.000Z", "node": "HTTP Request", "action": "retry_4", "delay_ms": 1600, "result": "success"}
        ]
      }
    },
    {
      "case_id": "F8_ADV_002",
      "description": "Legitimate pagination loop with proper termination",
      "expected_detection": false,
      "difficulty": "hard",
      "reason": "Same action repeated but with different page parameter and clear termination",
      "trace": {
        "execution_id": "adv-f8-002",
        "workflow_name": "data-fetch-pagination",
        "events": [
          {"timestamp": "2024-01-01T10:00:00.000Z", "node": "Fetch Data", "action": "fetch_page", "page": 1, "items_returned": 100},
          {"timestamp": "2024-01-01T10:00:01.000Z", "node": "Fetch Data", "action": "fetch_page", "page": 2, "items_returned": 100},
          {"timestamp": "2024-01-01T10:00:02.000Z", "node": "Fetch Data", "action": "fetch_page", "page": 3, "items_returned": 100},
          {"timestamp": "2024-01-01T10:00:03.000Z", "node": "Fetch Data", "action": "fetch_page", "page": 4, "items_returned": 50},
          {"timestamp": "2024-01-01T10:00:04.000Z", "node": "Process Data", "action": "complete", "total_items": 350}
        ]
      }
    },
    {
      "case_id": "F8_ADV_003",
      "description": "Batch processing with repeated similar operations",
      "expected_detection": false,
      "difficulty": "medium",
      "reason": "Many similar operations but processing different items",
