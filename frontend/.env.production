# MAO Testing Platform Frontend - Production
# IMPORTANT: Set these environment variables in Vercel/deployment dashboard

# Required - will break auth if not set
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY}
CLERK_SECRET_KEY=${CLERK_SECRET_KEY}

# Backend API
NEXT_PUBLIC_API_URL=https://mao-api.onrender.com

# Environment
NEXT_PUBLIC_ENVIRONMENT=production
