{
  "name": "mao-testing-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "echo 'Skipping lint - ESLint 9 config needs migration'",
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:public": "playwright test --project=public",
    "test:auth": "playwright test --project=authenticated",
    "test:all": "playwright test --project=api --project=public",
    "test:nav": "playwright test --project=authenticated tests/e2e/navigation",
    "test:pages": "playwright test --project=authenticated tests/e2e/pages",
    "test:full": "playwright test --project=api --project=public --project=authenticated",
    "test:setup-auth": "playwright test auth.setup.ts --headed",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.36.5",
    "@next/third-parties": "^16.1.6",
    "@tanstack/react-query": "^5.17.9",
    "@vercel/analytics": "^1.6.1",
    "clsx": "^2.1.0",
    "d3": "^7.8.5",
    "date-fns": "^3.2.0",
    "diff2html": "^3.4.47",
    "lucide-react": "^0.309.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.2",
    "recharts": "^2.10.4",
    "resend": "^6.9.1",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.41.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
