# MAO Testing Platform - Backend Environment Variables
# Copy to .env and fill in values

# =============================================================================
# REQUIRED - Application will fail without these
# =============================================================================

# Database connection (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mao

# Redis for rate limiting and caching
REDIS_URL=redis://localhost:6379

# JWT secret - MUST be at least 32 characters, random, no weak patterns
# Generate with: openssl rand -base64 32
JWT_SECRET=

# =============================================================================
# GOOGLE OAUTH AUTHENTICATION (Required for production)
# =============================================================================
# Get from https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# =============================================================================
# STRIPE BILLING (Required for paid plans)
# =============================================================================
# Get from https://dashboard.stripe.com/apikeys
# Test mode keys start with sk_test_ and pk_test_
# Production keys start with sk_live_ and pk_live_

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create products/prices in Stripe Dashboard)
STRIPE_PRICE_ID_STARTUP=price_...  # $49/month Startup plan
STRIPE_PRICE_ID_GROWTH=price_...   # $199/month Growth plan

# =============================================================================
# CLERK AUTHENTICATION (deprecated - for backward compatibility only)
# =============================================================================
# These can be removed after full migration to Google OAuth

# CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...
# CLERK_WEBHOOK_SECRET=whsec_...
# CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# =============================================================================
# OPTIONAL - Have sensible defaults
# =============================================================================

# Environment
DEBUG=false
ENVIRONMENT=production

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Detection algorithm settings
# Primary embedding model (stored in DB, 1024d):
#   BAAI/bge-m3 (default) - best quality, 63.0 MTEB, multilingual, 8K context
#   intfloat/e5-large-v2 - good quality, 61.5 MTEB, requires instruction prefix
# Fast embedding (runtime-only, 768d, use FastEmbeddingService):
#   nomic-ai/nomic-embed-text-v1.5 - 2x faster, 59.4 MTEB, for real-time comparisons
EMBEDDING_MODEL=BAAI/bge-m3
LOOP_DETECTION_WINDOW=7
STRUCTURAL_THRESHOLD=0.95
SEMANTIC_THRESHOLD=0.85

# CORS - comma-separated origins
CORS_ORIGINS=https://your-frontend.vercel.app

# Observability
OTEL_SERVICE_NAME=mao-platform
LOG_LEVEL=INFO

# Sentry error tracking (optional)
# Get DSN from https://sentry.io/settings/projects/YOUR_PROJECT/keys/
SENTRY_DSN=

# =============================================================================
# N8N INTEGRATION (Optional)
# =============================================================================
# Configure these to enable automatic n8n execution sync

# n8n instance URL (e.g., https://your-n8n.example.com or https://pisama.app.n8n.cloud)
N8N_HOST=

# n8n API key for authentication
# Get from: n8n Settings > API
N8N_API_KEY=

# Auto-sync interval in minutes (how often to pull new executions)
# Default: 5 minutes
N8N_SYNC_INTERVAL_MINUTES=5
